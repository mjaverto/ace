{
  "name": "@mjaverto/ace",
  "version": "0.0.0",
  "description": "Agent Conversation Exporter — render Claude Code, Codex, Pi, opencode transcripts to Markdown",
  "type": "module",
  "bin": {
    "ace": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mjaverto/ace.git"
  },
  "homepage": "https://github.com/mjaverto/ace#readme",
  "bugs": "https://github.com/mjaverto/ace/issues",
  "keywords": [
    "claude-code",
    "codex",
    "opencode",
    "pi",
    "transcripts",
    "markdown",
    "agent",
    "cli"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20",
    "execa": "^9",
    "tsup": "^8",
    "typescript": "^5.6",
    "vitest": "^2"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "yaml": "^2.5",
    "zod": "^3.23"
  }
}
